{
	"name": "clashofclans.js",
	"version": "4.0.0",
	"description": "JavaScript library for interacting with the Clash of Clans API",
	"author": "https://clashofclans.js.org",
	"license": "MIT",
	"main": "dist/index.js",
	"exports": {
		".": {
			"import": "./dist/index.mjs",
			"require": "./dist/index.js",
			"types": "./dist/index.d.ts"
		},
		"./api/": {
			"import": "./dist/types/api.mjs",
			"require": "./dist/types/api.js",
			"types": "./dist/types/api.d.ts"
		}
	},
	"bin": {
		"clashofclans-mcp": "dist/mcp/server.js"
	},
	"scripts": {
		"build": "tsc && gen-esm-wrapper dist/index.js dist/index.mjs",
		"prepare": "rimraf dist && npm run build",
		"mcp": "node dist/mcp/server.js",
		"lint:test": "eslint .",
		"lint:fix": "eslint --fix .",
		"test": "TZ=UTC jest --setupFiles dotenv/config --config ./jest.config.json",
		"test:watch": "npm run test -- --watch",
		"test:bun": "TZ=UTC bun test"
	},
	"files": [
		"dist"
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/clashperk/clashofclans.js.git"
	},
	"keywords": [
		"clash-of-clans-api",
		"clash-of-clans",
		"clash-api",
		"supercell",
		"coc"
	],
	"bugs": {
		"url": "https://github.com/clashperk/clashofclans.js/issues"
	},
	"homepage": "https://clashofclans.js.org",
	"standard-version": {
		"skip": {
			"changelog": false,
			"commit": true,
			"tag": true
		}
	},
	"devDependencies": {
		"@jest/globals": "^29.7.0",
		"@types/jest": "^29.5.14",
		"@types/node": "^20.19.37",
		"dotenv": "^16.0.2",
		"eslint": "^9.39.4",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-prettier": "^5.5.5",
		"gen-esm-wrapper": "^1.1.3",
		"jest": "^29.7.0",
		"prettier": "^3.0.1",
		"rimraf": "^5.0.1",
		"ts-jest": "^29.2.5",
		"typescript": "^5.1.6",
		"typescript-eslint": "^8.57.1"
	},
	"engines": {
		"node": ">=20.x",
		"bun": ">=1.0.0"
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.28.0",
		"zod": "^4.3.6"
	}
}
